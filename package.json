{
	"name": "pi-ext",
	"version": "0.1.0",
	"dependencies": {
		"@benvargas/pi-claude-code-use": "^1.0.1",
		"@mariozechner/pi-agent-core": "npm:@earendil-works/pi-agent-core@^0.80.3",
		"@mariozechner/pi-ai": "npm:@earendil-works/pi-ai@^0.80.3",
		"@mariozechner/pi-coding-agent": "npm:@earendil-works/pi-coding-agent@^0.80.3",
		"@mariozechner/pi-tui": "npm:@earendil-works/pi-tui@^0.80.3",
		"@sting8k/pi-vcc": "^0.3.5",
		"@tintinweb/pi-tasks": "^0.4.2",
		"typebox": "^1.1.32"
	},
	"optionalDependencies": {
		"@ataraxy-labs/sem": "^0.3.21"
	},
	"description": "Personal collection of Pi extensions, themes, and skills.",
	"keywords": [
		"pi-package",
		"pi",
		"pi-coding-agent"
	],
	"license": "MIT",
	"scripts": {
		"sem:evaluate": "node extensions/pi-sem/bin/sem-eval.mjs",
		"test": "npm run test:pi-sem && npm run test:leader-key",
		"test:pi-sem": "node --test extensions/pi-sem/core.test.mjs extensions/review/sem-guidance.test.mjs",
		"test:leader-key": "node --test extensions/leader-key/workflow-discovery.test.mjs",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"pi": {
		"extensions": [
			"./extensions/custom-footer/custom-footer.ts",
			"./extensions/review/review.ts",
			"./extensions/leader-key/index.ts",
			"./extensions/permissions/permissions.ts",
			"./extensions/session-query/session-query.ts",
			"./extensions/ask-user-question/index.ts",
			"./extensions/tool-pills/index.ts",
			"./extensions/pi-telescope/index.ts",
			"./extensions/pi-sem/index.ts",
			"./extensions/plannotator-annotate-tool/index.ts"
		],
		"skills": [
			"./skills/commit",
			"./skills/github",
			"./skills/visit-webpage",
			"./skills/web-search",
			"./skills/session-query",
			"./skills/sem",
			"./skills/pr-review-comments"
		],
		"prompts": [
			"./prompts"
		],
		"themes": [
			"./themes"
		]
	},
	"pi-subagents": {
		"agents": ["./agents"]
	},
	"private": true,
	"devDependencies": {
		"typescript": "^7.0.2"
	}
}
